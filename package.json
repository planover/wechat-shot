  "author": "planover",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/planover/wechat-shot.git"
  },
  "homepage": "https://github.com/planover/wechat-shot#readme",
  "bugs": {
    "url": "https://github.com/planover/wechat-shot/issues"
  },
  "type": "commonjs",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "puppeteer": "^25.3.0",
    "xlsx": "^0.18.5"
  }
